# Open-WebUI Umgebungsvariablen
# Diese Datei als .env kopieren und ggf. anpassen

# OpenAI-kompatibler Endpunkt des SGLang-Servers
# qwen36 = Docker-Container-Name im searxng_default Netzwerk
OPENAI_API_KEY=sk-fake
OPENAI_API_BASE_URL=http://qwen36:30000/v1

# Websuche via SearXNG
ENABLE_WEB_SEARCH=True
WEB_SEARCH_ENGINE=searxng
SEARXNG_QUERY_URL=http://searxng:8080/search?q=<query>&format=json
